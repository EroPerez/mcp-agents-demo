# ── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...         # optional, used as LiteLLM fallback

# ── LLM Gateway ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-demo-key
HELICONE_API_KEY=             # optional, enables Helicone observability
PORTKEY_API_KEY=              # optional

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO
MAX_CONCURRENT_TOOLS=5
AGENT_TIMEOUT_SECONDS=30

# ── Database (optional demo mode uses in-memory) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mcp_demo
REDIS_URL=redis://localhost:6379

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_TRANSPORT=stdio           # stdio | sse
MCP_HOST=0.0.0.0
MCP_PORT=8000
